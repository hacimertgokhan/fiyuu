{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist/packages",
    "rootDir": "packages",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@fiyuu/core": ["./packages/core/src/index.ts"],
      "@fiyuu/db": ["./packages/db/src/index.ts"],
      "@fiyuu/realtime": ["./packages/realtime/src/index.ts"],
      "@fiyuu/runtime": ["./packages/runtime/src/index.ts"],
      "@fiyuu/cli": ["./packages/cli/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "packages/create-fiyuu-app/**"
  ]
}
