#!/bin/sh
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENTRY_JS="$SCRIPT_DIR/../src/index.js"
ENTRY_TS="$SCRIPT_DIR/../src/index.ts"

if [ -f "$ENTRY_JS" ]; then
  exec node "$ENTRY_JS" "$@"
fi

if [ -f "$ENTRY_TS" ]; then
  if command -v tsx >/dev/null 2>&1; then
    exec tsx "$ENTRY_TS" "$@"
  fi

  if [ -x "$SCRIPT_DIR/../../../node_modules/.bin/tsx" ]; then
    exec "$SCRIPT_DIR/../../../node_modules/.bin/tsx" "$ENTRY_TS" "$@"
  fi
fi

echo "fiyuu CLI entry not found. Reinstall @fiyuu/cli." >&2
exit 1
