#!/usr/bin/env node

import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import { existsSync } from "node:fs";

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

// Try compiled JS first (npm published version)
const compiledEntry = resolve(__dirname, "../dist/index.js");
if (existsSync(compiledEntry)) {
  await import(compiledEntry);
} else {
  // Development mode: use tsx to run TypeScript directly
  const tsEntry = resolve(__dirname, "../src/index.ts");
  if (existsSync(tsEntry)) {
    // Re-exec with tsx
    const { execFileSync } = await import("node:child_process");
    const tsxPaths = [
      resolve(__dirname, "../node_modules/.bin/tsx"),
      resolve(__dirname, "../../../node_modules/.bin/tsx"),
    ];

    let tsxBin = null;
    for (const p of tsxPaths) {
      if (existsSync(p)) { tsxBin = p; break; }
    }

    if (!tsxBin) {
      // Try global tsx
      try {
        execFileSync("tsx", ["--version"], { stdio: "ignore" });
        tsxBin = "tsx";
      } catch {
        console.error("fiyuu: tsx not found. Install it: npm install -g tsx");
        process.exit(1);
      }
    }

    try {
      execFileSync(tsxBin, [tsEntry, ...process.argv.slice(2)], {
        stdio: "inherit",
        cwd: process.cwd(),
      });
    } catch (err) {
      process.exit(err.status ?? 1);
    }
  } else {
    console.error("fiyuu CLI entry not found. Reinstall @fiyuu/cli.");
    process.exit(1);
  }
}
