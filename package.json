{
  "name": "fiyuu",
  "version": "0.4.1",
  "type": "module",
  "exports": {
    "./client": "./client.ts"
  },
  "bin": {
    "fiyuu": "./bin/fiyuu.mjs"
  },
  "workspaces": [
    "packages/*",
    "examples/my-app",
    "examples/hacimertgokhan-me",
    "examples/blog",
    "examples/inventory",
    "examples/responsive-wrapper",
    "examples/fiyuu-website"
  ],
  "scripts": {
    "dev": "tsx packages/cli/src/index.ts dev",
    "build": "tsx packages/cli/src/index.ts build",
    "build:packages": "node ./scripts/build-packages.mjs",
    "start": "tsx packages/cli/src/index.ts start",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "benchmark:gea": "tsx scripts/benchmark-gea-runtime.ts",
    "benchmark:scorecard": "tsx scripts/benchmark-scorecard.ts",
    "sync": "tsx packages/cli/src/index.ts sync",
    "generate:page": "tsx packages/cli/src/index.ts generate page",
    "generate:action": "tsx packages/cli/src/index.ts generate action",
    "postinstall": "node scripts/patch-gea.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.14",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
