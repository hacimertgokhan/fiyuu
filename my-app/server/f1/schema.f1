message UserRecord {
  string id = 1;
  string name = 2;
  string email = 3;
  string role = 4;
  string passwordHash = 5;
  int64 createdAt = 6;
}

message SessionRecord {
  string id = 1;
  string userId = 2;
  string status = 3;
  int64 createdAt = 4;
}

message PostRecord {
  string id = 1;
  string title = 2;
  string excerpt = 3;
  string content = 4;
  string authorId = 5;
  bool published = 6;
  int64 createdAt = 7;
  int64 updatedAt = 8;
}
