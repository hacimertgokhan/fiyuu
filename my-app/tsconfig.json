{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "preserve",
    "jsxImportSource": "@geajs/core",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "server/**/*.ts", "lib/**/*.ts", "fiyuu.config.ts"]
}
